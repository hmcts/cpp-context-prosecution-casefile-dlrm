{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/json/schemas/court-document.json",
  "type": "object",
  "properties": {
    "courtDocumentId": {
      "description": "The technical identifier of a document",
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "documentCategory": {
      "$ref": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/json/schemas/document-category.json"
    },
    "name": {
      "type": "string"
    },
    "documentTypeId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "documentTypeDescription": {
      "type": "string"
    },
    "mimeType": {
      "type": "string"
    },
    "isRemoved": {
      "type": "boolean"
    },
    "amendmentDate": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/date"
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/core/courts/material.json"
      }
    },
    "containsFinancialMeans": {
      "type": "boolean"
    },
    "sendToCps": {
      "type": "boolean"
    },
    "documentTypeRBAC": {
      "$ref": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/json/schemas/documentTypeRBAC.json"
    },
    "seqNum": {
      "type": "integer"
    }
  },
  "required": [
    "courtDocumentId",
    "documentCategory",
    "name",
    "documentTypeId",
    "materials"
  ],
  "additionalProperties": false
}
