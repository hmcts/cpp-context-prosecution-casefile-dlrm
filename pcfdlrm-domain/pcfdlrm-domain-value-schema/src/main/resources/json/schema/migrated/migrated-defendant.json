{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/migrated/json/schemas/migrated-defendant.json",
  "type": "object",
  "description": "Defendant Details",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "prosecutorDefendantId": {
      "type": "string",
      "description": "The unique identifier that comes legacy systems"
    },
    "prosecutorDefendantReference": {
      "type": "string"
    },
    "asn": {
      "type": "string",
      "description": "Arrest / Summons number",
      "maxLength": 20
    },
    "documentationLanguage": {
      "type": "string",
      "description": "Language in which the defendant’s documents are written in legacy systems"
    },
    "hearingLanguage": {
      "type": "string",
      "description": "Language in which the defendant’s hearing is conducted in legacy systems"
    },
    "languageRequirement": {
      "type": "string",
      "description": "Notes about the defendant’s language needs, e.g. interpreter details",
      "maxLength": 150
    },
    "specificRequirements": {
      "type": "string",
      "description": "Notes about any help that the defendant may need when attending court – e.g. wheelchair access.",
      "maxLength": 150
    },
    "individual": {
      "$ref": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/json/schemas/individual.json"
    },
    "offences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/migrated/json/schemas/migrated-offence.json"
      }

    },
    "emailAddress1": {
      "type": "string"
    },

    "emailAddress2": {
      "type": "string"
    },

    "organisationName": {
      "type": "string"
    },

    "pncIdentifier": {
      "type": "string"
    },

    "telephoneNumberBusiness": {
      "type": "string"
    },
    "croNumber": {
      "type": "string"
    },

    "individualAliases": {
      "type": "array",
      "items": {
        "$ref": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/json/schemas/individual-alias.json"
      }
    },
    "aliasForCorporate": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "address": {
      "$ref": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/json/schemas/address.json"
    },
    "initiationCode": {
      "type": "string"
    }

  },
  "required": [
    "prosecutorDefendantId",
    "id",
    "offences"
  ]
}
