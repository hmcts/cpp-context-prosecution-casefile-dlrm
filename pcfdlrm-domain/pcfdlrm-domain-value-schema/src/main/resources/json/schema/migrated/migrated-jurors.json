{
	"$schema": "http://json-schema.org/draft-04/schema#",
	"id": "http://cpp.moj.gov.uk/prosecution/casefile/dlrm/migrated/json/schemas/migrated-jurors.json",
	"description": "The jurors of a verdict",
	"type": "object",
	"properties": {
		"numberOfJurors": {
			"type": "integer"
		},
		"numberOfSplitJurors": {
			"type": "integer"
		},
		"unanimous": {
			"type": "boolean"
		}
	},
	"additionalProperties": false,
	"required": [
		"numberOfJurors",
		"numberOfSplitJurors",
		"unanimous"
	]
}